# Environment Variables
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smitgate
DB_PASSWORD=your_secure_password

JWT_SECRET=your_jwt_secret_here
ENCRYPTION_SECRET=your_encryption_secret_here

# Frontend URL (used for OAuth redirect after callback)
# Dev:  http://localhost:3000
# Prod: https://YOUR_FRONTEND_URL
FRONTEND_URL=http://localhost:3000

# CORS allowed origins (comma-separated, no spaces)
# Dev:  http://localhost:3000,http://localhost:5173
# Prod: https://YOUR_FRONTEND_URL
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Facebook OAuth
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_REDIRECT_URI=http://localhost:8080/api/integrations/meta/oauth/callback

# Pancake POS
POSCAKE_BASE_URL=https://pos.pages.fm/api/v1
